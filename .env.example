# Copy to `.env` and fill in real values. `.env` is gitignored.

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Fastmail SMTP credentials
# Generate an app password: Fastmail → Settings → Password & Security → App passwords → New
# Scope to "Mail" only. Store the returned string here — you can't view it again after creation.
FASTMAIL_USERNAME=you@fastmail.com
FASTMAIL_APP_PASSWORD=your-app-password-here

# Where the digest + per-listing emails go. Usually your own address.
DIGEST_RECIPIENT=you@fastmail.com

# Plus-addressed From aliases. Fastmail supports `you+anything@fastmail.com` out of the box.
# The digest lands in Inbox; the per-listing emails are routed to PhilTracker/Listings
# by a Fastmail Sieve rule (`From contains "philtracker-listing"`).
DIGEST_SENDER=you+philtracker-digest@fastmail.com
LISTING_SENDER=you+philtracker-listing@fastmail.com
